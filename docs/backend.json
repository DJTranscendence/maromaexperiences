
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Maroma Experiences platform.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "accountType": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "type": "object",
      "description": "Global configuration for brand layout and UI parameters. Publicly readable.",
      "properties": {
        "navbarKerning": { "type": "number" },
        "navbarOffset": { "type": "number" },
        "loadingKerning": { "type": "number" },
        "loadingOffset": { "type": "number" }
      }
    },
    "Booking": {
      "title": "Booking",
      "type": "object",
      "description": "A customer reservation for a tour or workshop.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "tourId": { "type": "string" },
        "tourName": { "type": "string" },
        "tourDate": { "type": "string" },
        "numberOfAttendees": { "type": "number" },
        "totalPrice": { "type": "number" },
        "bookingStatus": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] },
        "bookedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CorporateProposal": {
      "title": "CorporateProposal",
      "type": "object",
      "description": "A custom itinerary request for corporate teams.",
      "properties": {
        "companyName": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "approved", "sent"] },
        "itinerary": { "type": "array", "items": { "type": "object" } }
      }
    },
    "SimulatorSession": {
      "title": "SimulatorSession",
      "type": "object",
      "description": "Records a team's game session in The Maroma Product Game.",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "emblem": { "type": "string" },
        "productType": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "config": { "type": "object" },
        "scores": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/settings/{settingId}",
        "definition": {
          "entityName": "AppSetting",
          "schema": { "$ref": "#/backend/entities/AppSetting" },
          "description": "Global application configuration. Read access is public."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles. Owners can read/write."
        }
      },
      {
        "path": "/bookings/{bookingId}",
        "definition": {
          "entityName": "Booking",
          "schema": { "$ref": "#/backend/entities/Booking" },
          "description": "Customer bookings. Owners and Admins can read."
        }
      },
      {
        "path": "/proposals/{proposalId}",
        "definition": {
          "entityName": "CorporateProposal",
          "schema": { "$ref": "#/backend/entities/CorporateProposal" },
          "description": "Corporate requests. Admins can manage."
        }
      },
      {
        "path": "/simulator_sessions/{sessionId}",
        "definition": {
          "entityName": "SimulatorSession",
          "schema": { "$ref": "#/backend/entities/SimulatorSession" },
          "description": "Stores game results for the leaderboard."
        }
      }
    ]
  }
}
