
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Maroma Experiences platform.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "accountType": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "SimulatorSession": {
      "title": "SimulatorSession",
      "type": "object",
      "description": "Records a team's game session in the Ethical Market Simulator.",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "productType": { "type": "string" },
        "ingredients": { "type": "array", "items": { "type": "string" } },
        "scores": {
          "type": "object",
          "properties": {
            "earth": { "type": "number" },
            "trust": { "type": "number" },
            "profit": { "type": "number" },
            "longevity": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/simulator_sessions/{sessionId}",
        "definition": {
          "entityName": "SimulatorSession",
          "schema": { "$ref": "#/backend/entities/SimulatorSession" },
          "description": "Stores game results for the leaderboard."
        }
      }
    ]
  }
}
