rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    
    // Admin check with specific email override for the workshop owner
    function isAdmin() { 
      return request.auth != null && (
        request.auth.token.email == "indispirit@gmail.com" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      ); 
    }

    // App Settings (Brand, Layout, etc.)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    match /users {
      allow list: if isAdmin();
    }
    
    // Simulator Game Sessions
    match /simulator_sessions/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    match /simulator_sessions {
      allow list: if true;
    }
    
    // Simulator Game Events
    match /simulator_events/{eventId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }
    match /simulator_events {
      allow list: if true;
    }
    
    // Experience Catalog
    match /tours/{tourId} { 
      allow read: if true; 
      // Allow signed-in users to increment the counter during booking
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['bookedSpaces']) || isAdmin();
      allow write: if isAdmin(); 
    }
    match /tours {
      allow list: if true;
    }
    
    // Corporate Proposals
    match /proposals/{proposalId} { 
      allow create: if isSignedIn(); 
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /proposals {
      allow list: if isAdmin();
    }
    
    // Bookings
    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /bookings {
      allow list: if isAdmin();
    }
    
    // Role Management
    match /roles_admin/{userId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }
    
    match /roles_facilitator/{anyDoc} { 
      allow read: if isSignedIn(); 
      // Explicitly allow administrators to manage the facilitator directory
      allow create, update, delete: if isAdmin();
    }
    match /roles_facilitator {
      allow list: if isSignedIn();
    }
    
    // Media Assets
    match /media/{mediaId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    match /media {
      allow list: if true;
    }
    
    // Deployment trigger comment: v1.1.4 - Allowed standard users to update tour counter for bookings
  }
}
