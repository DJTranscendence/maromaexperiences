
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }

    // App Settings (Brand, Layout, etc.)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }
    match /users {
      allow list: if isAdmin();
    }
    
    // Simulator Game Sessions (Completed Results)
    match /simulator_sessions/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    match /simulator_sessions {
      allow list: if true;
    }
    
    // Simulator Game Events (Real-time Joins/Phase Changes)
    match /simulator_events/{eventId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }
    match /simulator_events {
      allow list: if true;
    }
    
    // Experience Catalog
    match /tours/{tourId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    
    // Corporate Proposals
    match /proposals/{proposalId} { 
      allow create: if isSignedIn(); 
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /proposals {
      allow list: if isAdmin();
    }
    
    // Bookings
    match /bookings/{bookingId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }
    match /bookings {
      allow list: if isAdmin();
    }
    
    // Role Management
    match /roles_admin/{userId} { 
      allow read: if isSignedIn(); 
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    match /roles_admin {
      allow list: if isAdmin();
    }
    
    match /roles_facilitator/{userId} { 
      allow read: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
    match /roles_facilitator {
      allow list: if isAdmin();
    }
    
    // Media Assets
    match /media/{mediaId} { 
      allow read: if true; 
      allow write: if isAdmin(); 
    }
    match /media {
      allow list: if true;
    }
    
    // Deployment trigger comment: v1.0.6 - Added global read access for brand settings
  }
}
