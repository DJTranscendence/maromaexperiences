/**
 * MAROMA EXPERIENCES - FIRESTORE SECURITY RULES
 *
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict identity-based security model. Access is governed by a 
 * combination of path-based ownership (User-specific data) and Database-Backed Access 
 * Control (DBAC) for administrative and facilitator roles.
 *
 * DATA STRUCTURE:
 * - User Profiles & Notifications: Nested under /users/{userId} for strict ownership.
 * - Roles: Specialized top-level collections (/roles_admin, /roles_facilitator) define permissions.
 * - Global Content: /tours, /locations, /tourCategories, and /addOns are globally readable 
 *   but restricted for modification to authorized personnel.
 * - Transactional Data: /bookings are accessible by the creator, assigned facilitators, and admins.
 *
 * KEY SECURITY DECISIONS:
 * 1. Authorization Independence: Critical fields (tourOwnerId, facilitatorIds, userId) are 
 *    denormalized into documents to avoid expensive get() calls in rules.
 * 2. State-Based Visibility: Public access to Tours and Schedules is gated by status flags 
 *    (isActive, status), requiring clients to filter queries appropriately.
 * 3. Prototyping Flexibility: Logic enforces who can access data but allows for schema 
 *    evolution by not enforcing strict property types for general content.
 * 4. Relational Integrity: On creation, we strictly verify that ownership fields in 
 *    the data match the authenticated user's identity.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Removed the 'isExistingOwner' function as it was unused and incorrectly referenced 'resource'.
    // The check `resource != null` is typically implicit or handled in specific contexts
    // where 'resource' is already guaranteed to exist (e.g., update, delete operations).

    /** @description Checks if the user has the 'Admin' role via DBAC. */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the user has the 'Facilitator' role via DBAC. */
    function isFacilitator() {
      return exists(/databases/$(database)/documents/roles_facilitator/$(request.auth.uid));
    }

    /** @description Checks if a user is present in a list of IDs (collaborators/facilitators). */
    function isMember(memberList) {
      return isSignedIn() && request.auth.uid in memberList;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Access to user profile data.
     * @path /users/{userId}
     * @allow Authenticated user reading/updating their own profile.
     * @deny User 'B' trying to read or modify User 'A's profile.
     * @principle Path-based ownership and relational integrity.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; 
    }

    /**
     * @description DBAC collection for Admin roles.
     * @path /roles_admin/{userId}
     * @allow Admins managing roles; users checking their own role status.
     * @deny Non-admins creating or modifying admin roles.
     */
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description DBAC collection for Facilitator roles.
     * @path /roles_facilitator/{userId}
     * @allow Admins managing roles; facilitators checking their own status.
     * @deny Non-admins creating or modifying facilitator roles.
     */
    match /roles_facilitator/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Global categories for tours.
     * @path /tourCategories/{categoryId}
     * @allow Any signed-in user reading; only admins modifying.
     * @deny Unauthenticated reading; non-admin writing.
     */
    match /tourCategories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Geographical locations for venues.
     * @path /locations/{locationId}
     * @allow Any signed-in user reading; only admins modifying.
     * @deny Unauthenticated reading; non-admin writing.
     */
    match /locations/{locationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Tour templates and definitions.
     * @path /tours/{tourId}
     * @allow Public read if isActive; Admin/Owner read/write.
     * @deny Non-owners updating tour details.
     * @principle State-based access control and owner-only writes.
     */
    match /tours/{tourId} {
      // NOTE: Clients must query isActive == true to list publicly.
      allow get, list: if isAdmin() || (resource.data.isActive == true);
      allow create: if isAdmin() && request.resource.data.tourOwnerId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.tourOwnerId);
      allow delete: if isAdmin(); // 'resource != null' is implicit for a delete operation on an existing document.
    }

    /**
     * @description Specific scheduled instances of tours.
     * @path /tourSchedules/{scheduleId}
     * @allow Public read if status is Scheduled; Admin/Facilitator read/write.
     * @deny Regular users modifying schedule status or capacity.
     */
    match /tourSchedules/{scheduleId} {
      allow get, list: if isAdmin() || isMember(resource.data.facilitatorIds) || resource.data.status == 'Scheduled';
      allow create: if isAdmin() || isFacilitator();
      allow update: if isAdmin() || isMember(resource.data.facilitatorIds);
      allow delete: if isAdmin(); // 'resource != null' is implicit for a delete operation on an existing document.
    }

    /**
     * @description Optional add-ons for corporate packages.
     * @path /addOns/{addOnId}
     * @allow Signed-in users reading; Admins modifying.
     * @deny Non-admin writing.
     */
    match /addOns/{addOnId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Reservation records.
     * @path /bookings/{bookingId}
     * @allow The booker, assigned facilitators, or admins.
     * @deny User 'B' viewing User 'A's private booking.
     * @principle Authorization independence via denormalized UIDs.
     */
    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || isOwner(resource.data.userId) || isMember(resource.data.facilitatorIds);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin(); // 'resource != null' is implicit for a delete operation on an existing document.
    }

    /**
     * @description User-specific notifications.
     * @path /users/{userId}/notifications/{notificationId}
     * @allow Recipient reading/updating their own notifications.
     * @deny Reading notifications belonging to another user.
     * @principle Path-based segregation.
     */
    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isAdmin(); // Notifications usually created by system/admin.
      allow update: if isOwner(userId) && request.resource.data.recipientUserId == resource.data.recipientUserId;
      allow delete: if isOwner(userId); // 'resource != null' is implicit for a delete operation on an existing document.
    }

  }
}