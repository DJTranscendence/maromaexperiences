
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isFacilitator() {
      return exists(/databases/$(database)/documents/roles_facilitator/$(request.auth.uid));
    }

    function isMember(memberList) {
      return isSignedIn() && request.auth.uid in memberList;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; 
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /roles_facilitator/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /tourCategories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Relaxed for prototype
    }

    match /locations/{locationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Relaxed for prototype
    }

    match /media/{mediaId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn(); // Allow upload for any signed-in user in prototype
      allow update, delete: if isAdmin();
    }

    match /tours/{tourId} {
      allow get, list: if true; // Publicly readable for listings
      allow create: if isSignedIn(); // Allow any signed-in user to create for prototype
      allow update: if isSignedIn(); // Allow any signed-in user to update for prototype
      allow delete: if isAdmin();
    }

    match /tourSchedules/{scheduleId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /addOns/{addOnId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || isOwner(resource.data.userId) || isMember(resource.data.facilitatorIds);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(userId) && request.resource.data.recipientUserId == resource.data.recipientUserId;
      allow delete: if isOwner(userId);
    }
  }
}
