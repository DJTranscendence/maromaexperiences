rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)); }

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }
    match /simulator_sessions/{sessionId} {
      allow read: if true;
      allow create: if true; // Open to participants
      allow update, delete: if isAdmin();
    }
    match /simulator_events/{eventId} {
      allow read, create: if true; // Open to participants for real-time join alerts
    }
    match /tours/{tourId} { allow read: if true; allow write: if isAdmin(); }
    match /proposals/{proposalId} { allow create, read: if isSignedIn(); allow update, delete: if isAdmin(); }
    match /roles_admin/{userId} { allow read: if isSignedIn(); }
    match /media/{mediaId} { allow read: if true; }
  }
}
